# ==========================================
# 3. MAIN SCRIPT
# ==========================================

def perform_decision_tree_analysis():
    # 1. Load Data
    filename = input("Enter the CSV filename: ")
    data = []
    try:
        with open(filename, 'r') as file:
            reader = csv.reader(file)
            headers = next(reader)
            # Load non-empty rows
            for row in reader:
                if len(row) > 0:
                    data.append(row)
    except FileNotFoundError:
        print("File not found.")
        return

    if not data:
        print("Dataset is empty.")
        return

    target_index = len(headers) - 1
    target_labels = get_column(data, target_index)

    # 2. Calculate Parent Entropy
    parent_entropy = calculate_entropy(target_labels)
    print(f"\nSTEP 1: CALCULATE TOTAL ENTROPY")
    print(f"Total Records: {len(data)}")
    print(f"Target Distribution: {get_distribution(target_labels)}")
    print(f"Entropy(S) = {parent_entropy:.4f}")
    print("-" * 50)

    # 3. Calculate Information Gain for each feature manually for the initial console printout
    features_gains = {}

    print("STEP 2: CALCULATE INFORMATION GAIN FOR EACH FEATURE")
    for i in range(len(headers) - 1):
        feature_name = headers[i]
        feature_values = get_column(data, i)
        unique_vals = set(feature_values)

        print(f"\nAnalyzing Feature: {feature_name}")
        weighted_entropy = 0

        # Calculate Entropy for each unique value in the feature
        for val in unique_vals:
            # Get subset of target labels where feature == val
            subset_labels = [data[r][target_index] for r in range(len(data)) if data[r][i] == val]
            val_entropy = calculate_entropy(subset_labels)
            weight = len(subset_labels) / len(data)
            weighted_entropy += weight * val_entropy

            print(f"  - Value '{val}': Count={len(subset_labels)}, Entropy={val_entropy:.4f}")

        # Information Gain = Parent Entropy - Weighted Average Entropy
        info_gain = parent_entropy - weighted_entropy
        features_gains[feature_name] = info_gain

        print(f"Weighted Average Entropy for {feature_name} = {weighted_entropy:.4f}")
        print(f"Information Gain({feature_name}) = {parent_entropy:.4f} - {weighted_entropy:.4f} = {info_gain:.4f}")

    # 4. Show Root Node Step Results
    print("\n" + "="*50)
    print("ROOT SPLIT SUMMARY: INFORMATION GAINS")
    print("="*50)
    best_feature = None
    max_gain = -1
    for feat, gain in features_gains.items():
        print(f"{feat:<15}: {gain:.4f}")
        if gain > max_gain:
            max_gain = gain
            best_feature = feat

    print("-" * 50)
    print(f"THE ROOT NODE IS: {best_feature.upper()}")
    print(f"Reason: Highest Information Gain ({max_gain:.4f})")
    print("="*50)

    # 5. Build and print the complete Decision tree recursively
   # print("\nSTEP 3: BUILDING THE ENTIRE TREE...\n")

    available_features = list(range(len(headers) - 1))

    # Storing domains so when recursive branches are drawn they include options
    # even if one of those branches becomes structurally empty during recursions
    feature_domains = {i: set([row[i] for row in data]) for i in available_features}

    trained_tree = build_tree(data, headers, available_features, target_index, feature_domains)

""" print("==================================================")
    print(" FINAL DECISION TREE STRUCTURE")
    print("==================================================")
    print_tree(trained_tree)
    print("\n==================================================")"""

if __name__ == "__main__":
    perform_decision_tree_analysis()
